{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "report-idea",
  "main": "src/index.js",
  "compatibility_date": "2025-06-01",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": ["/changelog.json"]
  },
  "version_metadata": {
    "binding": "CF_VERSION_METADATA"
  },
  "r2_buckets": [
    { "binding": "RESEARCH", "bucket_name": "samsungda-research" }
  ],
  "observability": {
    "enabled": true
  }
}
